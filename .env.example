APP_NAME="PM-OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://pmos.test
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# Central Database (SaaS Management)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=pm_central
DB_USERNAME=pmos
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Session
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null

# S3-Compatible Storage (MinIO)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=pmos_minio
AWS_SECRET_ACCESS_KEY=secret123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=pmos-documents
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Multi-Tenancy
TENANCY_DB_PREFIX=pm_tenant_
TENANCY_CENTRAL_DOMAINS=pmos.test,admin.pmos.test

# Horizon
HORIZON_PREFIX=pmos_horizon:

# Reverb (WebSocket)
REVERB_APP_ID=pmos
REVERB_APP_KEY=pmos-key
REVERB_APP_SECRET=pmos-secret
REVERB_HOST=reverb
REVERB_PORT=8080

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# SMS Provider (Unifonic)
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=PMOS

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Encryption
DOCUMENTS_ENCRYPTION_KEY=

# Feature Flags
PENNANT_STORE=database
